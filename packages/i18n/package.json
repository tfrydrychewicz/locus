{
  "name": "@locus/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --config-path=../.. src",
    "lint:fix": "biome check --write --config-path=../.. src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "i18next-parser": "^9.4.0",
    "jsdom": "^29.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  },
  "dependencies": {
    "i18next": "^25.8.18",
    "intl-messageformat": "^11.1.2",
    "react-i18next": "^16.5.8"
  }
}
