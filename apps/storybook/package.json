{
  "name": "@locus/storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build -o dist",
    "lint": "biome check --config-path=../.. src",
    "lint:fix": "biome check --write --config-path=../.. src",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@locus/tokens": "workspace:*",
    "@locus/ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/blocks": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "storybook": "^8.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
